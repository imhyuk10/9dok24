# 9dok24 Environment Variables
#
# Copy this file to .env and fill in the values if needed.
# OAuth credentials (Client ID / Secret) are entered through the in-app
# setup screen on first launch and stored in Electron's userData directory —
# they do NOT need to be set here.

# Dev server port (optional — defaults to 8080, set by vite.config.ts)
# VITE_DEV_SERVER_PORT=8080
